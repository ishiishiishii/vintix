# Copy to .env. Container runs only as non-root user CONTAINER_USER (default kawa37).
# Set HOST_UID / HOST_GID to your host account so ./ bind mount permissions match:
#   id -u
#   id -g
HOST_UID=1000
HOST_GID=1000
CONTAINER_USER=kawa37

# Optional: Weights & Biases (leave empty for offline / disabled)
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=
